{
  "name": "@regenera/outbox-relay",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test:redis": "jest --runInBand --forceExit --testPathPattern=outbox-relay.integration.spec.ts",
    "test:postgres": "node -e \"if(!process.env.DATABASE_URL){console.error('DATABASE_URL required for test:postgres');process.exit(1)}\" && jest --runInBand --forceExit --testPathPattern=outbox-postgres.integration.spec.ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "bullmq": "^5.34.5",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}