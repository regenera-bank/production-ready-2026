import \{ BadRequestException, Body, Controller, Headers, HttpCode, Post \} from '@nestjs/common';\
import \{ computeConsentEvidenceHash \} from './entities/consent.entities';\
import \{ RateLimit, RATE_LIMIT_POLICIES \} from '../common/rate-limit.guard';\
\
interface CreateConsentBody \{\
  scopes?: string[];\
  legalTextVersion?: string;\
  expiresAt?: string;\
  channel?: 'MOBILE' | 'WEB';\
\}\
\
@Controller('consents')\
export class ConsentsController \{\
  @Post()\
  @HttpCode(201)\
  @RateLimit(RATE_LIMIT_POLICIES.consentMutation)\
  create(\
    @Body() body: CreateConsentBody,\
    @Headers('x-user-id') userId: string | undefined,\
  ): \{ evidenceHash: string; status: 'PENDING' \} \{\
    if (!userId || !body.scopes?.length || !body.legalTextVersion || !body.expiresAt || !body.channel) \{\
      throw new BadRequestException(\{ code: 'CONSENT_PAYLOAD_INVALID' \});\
    \}\
