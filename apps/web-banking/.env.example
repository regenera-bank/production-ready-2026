# Proxy local do BFF (vite.config.ts encaminha /api → localhost:3200/v1)
# BFF local (proxy vite → :3200/v1)
VITE_API_URL=/api

# Gemini só no backend em produção — deixe vazio no frontend homolog
# GEMINI_API_KEY=

# Firebase Web (público no bundle — restrinja no console Firebase por domínio)
# NUNCA use o valor da chave como nome da variável:
#   errado: import.meta.env['AIzaSy...']
#   certo:  import.meta.env.VITE_FIREBASE_API_KEY
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Em dev local, npm run dev:canal-web injeta VITE_FIREBASE_* a partir de bff/web-bff/.env

# Segredos de backend — NÃO colocar no frontend:
# GEMINI_API_KEY, PROMETEO_API_KEY (legado — canal web usa Firebase)