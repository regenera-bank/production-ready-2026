# @regenera/bank-core
# DNSSEC Activation and Strict Key Management Configuration
# Protects against DNS spoofing/cache poisoning for banking domains.

{
  "dnssecConfig": {
    "state": "on",
    "nonExistence": "nsec3",
    "defaultKeySpecs": [
      {
        "algorithm": "rsasha512",
        "keyLength": 2048,
        "keyType": "keySigning",
        "kind": "dns#dnsKeySpec"
      },
      {
        "algorithm": "rsasha256",
        "keyLength": 1024,
        "keyType": "zoneSigning",
        "kind": "dns#dnsKeySpec"
      }
    ]
  }
}
