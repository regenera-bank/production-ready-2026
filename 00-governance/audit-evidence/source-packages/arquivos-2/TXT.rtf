    \});\
  \}\
\
  // saldo \'e9 SUM das linhas, sempre. n\'e3o existe coluna balance pra\
  // algu\'e9m "ajustar". lockAccount=true trava a linha da conta antes\
  // de somar \'97 obrigat\'f3rio pra quem vai decidir d\'e9bito com base nesse\
  // n\'famero, sen\'e3o dois processos leem o mesmo saldo e gastam duas vezes.\
  async signedBalance(\
    runner: QueryRunner,\
    ledgerAccountId: string,\
    lockAccount = false,\
  ): Promise<Money> \{\
    if (lockAccount) \{\
      await runner.query(\
        `SELECT id FROM ledger_accounts WHERE id = $1 FOR UPDATE`,\
        [ledgerAccountId],\
      );\
    \}\
    const [row]: Array<\{ balance: string | null \}> = await runner.query(\
      `SELECT COALESCE(SUM(CASE WHEN direction = 'DEBIT' THEN -amount_cents\
                                ELSE amount_cents END), 0)::text AS balance\
         FROM ledger_lines WHERE ledger_account_id = $1`,\
      [ledgerAccountId],\
    );\
    return Money.fromCents(row.balance ?? '0');\
  \}\
