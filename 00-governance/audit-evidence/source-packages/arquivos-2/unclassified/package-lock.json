async function openVaultOrDie(): Promise<void> {
const available = await SecureStore.isAvailableAsync();

if (!available) {
throw new Error('secure store unavailable');
    }
}

async function ensureDeviceSecret(): Promise<void> {
const current = await SecureStore.getItemAsync(DEVICE_SECRET_KEY);

if (current && DEVICE_SECRET_PATTERN.test(current)) {
return;
    }

if (current) {
await SecureStore.deleteItemAsync(DEVICE_SECRET_KEY);
    }

const fresh = await createDeviceSecret();

await SecureStore.setItemAsync(DEVICE_SECRET_KEY, fresh,
    {
keychainAccessible: SecureStore.WHEN_UNLOCKED_THIS_DEVICE_ONLY,
    });
}

async function verifyVault(): Promise<void> {
try {
await openVaultOrDie();

