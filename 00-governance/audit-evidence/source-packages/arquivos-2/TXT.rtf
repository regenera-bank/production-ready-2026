  async emitAlert(\
    senderAccountId: string,\
    evaluation: StructuringEvaluation,\
  ): Promise<string | null> \{\
    if (!evaluation.triggered) return null;\
    const dedupSource = [\
      AmlPixStructuring001Rule.RULE_CODE,\
      senderAccountId,\
      evaluation.windowStart.toISOString().slice(0, 13),\
    ].join('|');\
