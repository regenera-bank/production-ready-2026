    const staff: AuthenticatedStaff | undefined = request.staff;\
    if (!staff) \{\
      throw new ForbiddenException(\{ code: 'STAFF_CONTEXT_MISSING' \});\
    \}\
\
    const granted = permissionsForRoles(staff.roles);\
    const missing = required.filter((permission) => !granted.has(permission));\
    if (missing.length > 0) \{\
      throw new ForbiddenException(\{ code: 'PERMISSION_DENIED', missing \});\
    \}\
