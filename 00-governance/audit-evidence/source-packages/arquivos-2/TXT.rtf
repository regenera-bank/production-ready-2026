  if (strict) \{\
    for (const binding of bindings) \{\
      if (binding.isMock || binding.implementation.includes('adapters/mock')) \{\
        violations.push(\
          `Provider mock proibido em $\{mode\}: $\{binding.domain\} \uc0\u8594  $\{binding.implementation\}`,\
        );\
