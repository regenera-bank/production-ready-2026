      `UPDATE idempotency_keys\
          SET locked_until = now() + interval '$\{LEASE_SECONDS\} seconds'\
        WHERE resource_id = $1 AND idempotency_key = $2`,\
      [resourceId, idempotencyKey],\
    );\
