// dois cintos de seguran\'e7a porque o carro transporta dinheiro alheio.\
\
import \{ Injectable, UnprocessableEntityException \} from '@nestjs/common';\
import \{ QueryRunner \} from 'typeorm';\
import \{ Money \} from '../domain/money.value-object';\
import \{ LedgerDirection \} from '../domain/state-machines';\
import \{ MetricsService \} from '../metrics/metrics.service';\
\
export interface PostingLine \{\
  ledgerAccountId: string;\
  direction: LedgerDirection;\
  amount: Money;\
\}\
\
export interface PostingRequest \{\
  referenceType: string;\
  referenceId: string;\
  description: string;\
  lines: PostingLine[];\
  correlationId: string;\
  causationId?: string;\
  eventType: string;\
  eventPayload: Record<string, unknown>;\
\}\
\
export class UnbalancedPostingError extends UnprocessableEntityException \{\
  constructor(imbalanceCents: string) \{\
    super(\{ code: 'LEDGER_UNBALANCED', imbalanceCents \});\
  \}\
\}\
\
@Injectable()\
export class LedgerPostingService \{\
  constructor(private readonly metrics: MetricsService) \{\}\
\
  // lan\'e7amento + linhas + evento de outbox na MESMA transa\'e7\'e3o do chamador.\
  // se qualquer parte falhar, nada existe. evento sem lan\'e7amento ou\
  // lan\'e7amento sem evento s\'e3o as duas formas de mentir pra auditoria.\
  async post(runner: QueryRunner, request: PostingRequest): Promise<string> \{\
    if (request.lines.length < 2) \{\
      throw new UnprocessableEntityException(\{ code: 'LEDGER_MIN_TWO_LINES' \});\
    \}\
    let imbalance = 0n;\
    for (const line of request.lines) \{\
      if (!line.amount.isPositive()) \{\
        // valor negativo numa linha \'e9 algu\'e9m tentando esperteza com sinal.\
        // d\'e9bito e cr\'e9dito j\'e1 carregam o sinal; o valor \'e9 sempre positivo.\
        throw new UnprocessableEntityException(\{ code: 'LEDGER_LINE_NOT_POSITIVE' \});\
      \}\
      imbalance += line.direction === LedgerDirection.DEBIT\
        ? line.amount.amountCents\
        : -line.amount.amountCents;\
    \}\
    if (imbalance !== 0n) \{\
      this.metrics.increment('ledger_imbalance_total', \{ reference: request.referenceType \});\
      throw new UnbalancedPostingError(imbalance.toString(10));\
    \}\
\
    const [entry]: Array<\{ id: string \}> = await runner.query(\
      `INSERT INTO ledger_entries (reference_type, reference_id, description)\
       VALUES ($1, $2, $3) RETURNING id`,\
      [request.referenceType, request.referenceId, request.description],\
    );\
\
    for (const line of request.lines) \{\
      await runner.query(\
        `INSERT INTO ledger_lines (entry_id, ledger_account_id, direction, amount_cents)\
         VALUES ($1, $2, $3, $4::bigint)`,\
        [entry.id, line.ledgerAccountId, line.direction, line.amount.toCentsString()],\
      );\
    \}\
\
    await runner.query(\
      `INSERT INTO outbox_events\
         (aggregate_type, aggregate_id, event_type, payload, correlation_id, causation_id)\
       VALUES ($1, $2, $3, $4::jsonb, $5, $6)`,\
      [\
        request.referenceType,\
        request.referenceId,\
        request.eventType,\
        JSON.stringify(\{ ...request.eventPayload, ledgerEntryId: entry.id \}),\
        request.correlationId,\
        request.causationId ?? null,\
      ],\
    );\
\
    this.metrics.increment('ledger_entries_total', \{ reference: request.referenceType \});\
    return entry.id;\
  \}\
\
  // estorno nunca toca no lan\'e7amento original. nasce um lan\'e7amento novo\
  // com as pernas invertidas apontando pro mesmo agregado. o hist\'f3rico\
  // mostra o erro E a corre\'e7\'e3o \'97 apagar o erro \'e9 o crime, n\'e3o comet\'ea-lo.\
  async reverse(\
    runner: QueryRunner,\
    originalEntryId: string,\
    reason: string,\
    correlationId: string,\
  ): Promise<string> \{\
    const original: Array<\{\
      reference_type: string;\
      reference_id: string;\
    \}> = await runner.query(\
      `SELECT reference_type, reference_id FROM ledger_entries WHERE id = $1 FOR UPDATE`,\
      [originalEntryId],\
    );\
    if (original.length === 0) \{\
      throw new UnprocessableEntityException(\{ code: 'LEDGER_ENTRY_NOT_FOUND' \});\
    \}\
\
    // estorno do estorno seria criar dinheiro. a descri\'e7\'e3o determin\'edstica\
    // + unique constraint fazem a segunda chamada devolver o id da primeira.\
    const existing: Array<\{ id: string \}> = await runner.query(\
      `SELECT id FROM ledger_entries\
        WHERE reference_type = $1 AND reference_id = $2 AND description = $3`,\
      [original[0].reference_type, original[0].reference_id, `REVERSAL:$\{originalEntryId\}`],\
    );\
    if (existing.length > 0) \{\
      return existing[0].id;\
    \}\
\
    const lines: Array<\{\
      ledger_account_id: string;\
      direction: LedgerDirection;\
      amount_cents: string;\
    \}> = await runner.query(\
      `SELECT ledger_account_id, direction, amount_cents::text AS amount_cents\
         FROM ledger_lines WHERE entry_id = $1 ORDER BY line_seq`,\
      [originalEntryId],\
    );\
\
    return this.post(runner, \{\
      referenceType: original[0].reference_type,\
      referenceId: original[0].reference_id,\
      description: `REVERSAL:$\{originalEntryId\}`,\
      correlationId,\
      causationId: originalEntryId,\
      eventType: 'LEDGER_ENTRY_REVERSED',\
      eventPayload: \{ originalEntryId, reason \},\
      lines: lines.map((line) => (\{\
        ledgerAccountId: line.ledger_account_id,\
