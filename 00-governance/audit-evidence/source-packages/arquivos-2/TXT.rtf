    \} else \{\
      throw new MoneyError('Tipo n\'e3o suportado para Money', 'MONEY_UNSUPPORTED_TYPE');\
    \}\
    if (cents > MAX_ABS_CENTS || cents < -MAX_ABS_CENTS) \{\
      throw new MoneyError('Valor excede capacidade BIGINT', 'MONEY_OVERFLOW');\
    \}\
