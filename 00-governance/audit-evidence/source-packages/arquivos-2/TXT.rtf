    if (lockedUntil > Date.now()) \{\
      this.metrics.increment('idempotency_conflict_total', \{ reason: 'in_flight' \});\
      throw new IdempotencyInFlight(\
        idempotencyKey,\
        Math.ceil((lockedUntil - Date.now()) / 1000),\
      );\
    \}\
