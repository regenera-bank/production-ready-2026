{
  "name": "@regenera/core-bank",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/public-api.js",
  "types": "dist/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public-api.d.ts",
      "default": "./dist/public-api.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node scripts/clean-artifacts.mjs",
    "build": "nest build",
    "postbuild": "node -e \"const fs=require('fs');const req=['dist/public-api.js','dist/core-bank.module.js','dist/main.js'];const miss=req.filter(f=>!fs.existsSync(f));if(miss.length){console.error('dist incompleto:',miss.join(', '));if(fs.existsSync('dist'))console.error('dist contém:',fs.readdirSync('dist').slice(0,20).join(', '));process.exit(1)}\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage",
    "test:load": "jest --runInBand src/load",
    "load:50k": "node scripts/run-load-50k.mjs",
    "evidence:generate": "node scripts/generate-evidence.mjs",
    "gate:release": "npm run lint && npm test && npm run build && npm run evidence:generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}