import \{ Injectable, Logger \} from '@nestjs/common';\
import \{ DataSource \} from 'typeorm';\
import \{ MetricsService \} from '../metrics/metrics.service';\
\
export interface EventPublisher \{\
  publish(event: \{\
    id: string;\
    eventType: string;\
    aggregateType: string;\
    aggregateId: string;\
    payload: Record<string, unknown>;\
    correlationId: string;\
    schemaVersion: number;\
  \}): Promise<void>;\
\}\
\
const MAX_RETRIES = 8;\
const BASE_BACKOFF_SECONDS = 5;\
const MAX_BACKOFF_SECONDS = 3600;\
\
@Injectable()\
export class OutboxDispatcherService \{\
  private readonly logger = new Logger(OutboxDispatcherService.name);\
\
  constructor(\
    private readonly dataSource: DataSource,\
    private readonly publisher: EventPublisher,\
    private readonly metrics: MetricsService,\
  ) \{\}\
\
  // FOR UPDATE SKIP LOCKED permite v\'e1rios workers sem disputa; o lote vira\
  // PROCESSING dentro do claim, ent\'e3o worker morto devolve o lote ao PENDING\
  // pelo pr\'f3prio rollback.\
  async dispatchBatch(batchSize = 50): Promise<\{ published: number; failed: number \}> \{\
    const runner = this.dataSource.createQueryRunner();\
    await runner.connect();\
    await runner.startTransaction();\
    let claimed: Array<\{\
      id: string;\
      aggregate_type: string;\
      aggregate_id: string;\
      event_type: string;\
      schema_version: number;\
      payload: Record<string, unknown>;\
      correlation_id: string;\
      retry_count: number;\
    \}>;\
    try \{\
      claimed = await runner.query(\
        `WITH batch AS (\
           SELECT id FROM outbox_events\
            WHERE status = 'PENDING' AND next_retry_at <= now()\
            ORDER BY created_at\
            LIMIT $1\
            FOR UPDATE SKIP LOCKED)\
         UPDATE outbox_events o\
            SET status = 'PROCESSING'\
           FROM batch\
          WHERE o.id = batch.id\
          RETURNING o.id, o.aggregate_type, o.aggregate_id, o.event_type,\
                    o.schema_version, o.payload, o.correlation_id, o.retry_count`,\
        [batchSize],\
      );\
      await runner.commitTransaction();\
    \} catch (error: unknown) \{\
      await runner.rollbackTransaction();\
      await runner.release();\
      throw error;\
    \}\
    await runner.release();\
\
    let published = 0;\
    let failed = 0;\
    for (const event of claimed) \{\
      try \{\
        await this.publisher.publish(\{\
          id: event.id,\
          eventType: event.event_type,\
          aggregateType: event.aggregate_type,\
          aggregateId: event.aggregate_id,\
          payload: event.payload,\
          correlationId: event.correlation_id,\
          schemaVersion: event.schema_version,\
        \});\
        await this.dataSource.query(\
          `UPDATE outbox_events\
              SET status = 'COMPLETED', published_at = now()\
            WHERE id = $1 AND status = 'PROCESSING'`,\
          [event.id],\
        );\
        published += 1;\
      \} catch (error: unknown) \{\
        failed += 1;\
        await this.recordFailure(event.id, event.retry_count, error);\
      \}\
    \}\
\
    await this.refreshGauges();\
    return \{ published, failed \};\
  \}\
\
  private async recordFailure(eventId: string, retryCount: number, error: unknown): Promise<void> \{\
    const message = error instanceof Error ? error.message : String(error);\
    const nextRetry = retryCount + 1;\
    if (nextRetry >= MAX_RETRIES) \{\
      await this.dataSource.query(\
        `UPDATE outbox_events\
            SET status = 'FAILED', retry_count = $2, last_error = $3\
          WHERE id = $1`,\
        [eventId, nextRetry, message.slice(0, 500)],\
      );\
      this.logger.error(`Evento $\{eventId\} esgotou retries: $\{message.slice(0, 200)\}`);\
      return;\
    \}\
    const backoff = Math.min(BASE_BACKOFF_SECONDS * 2 ** retryCount, MAX_BACKOFF_SECONDS);\
    await this.dataSource.query(\
      `UPDATE outbox_events\
          SET status = 'PENDING', retry_count = $2, last_error = $3,\
              next_retry_at = now() + ($4 || ' seconds')::interval\
        WHERE id = $1`,\
      [eventId, nextRetry, message.slice(0, 500), String(backoff)],\
    );\
  \}\
\
  // Reprocessamento de dead letter \'e9 decis\'e3o humana: exige ator identificado,\
  // que fica registrado no last_error junto do reenvio.\
  async requeueDeadLetter(eventId: string, actor: string): Promise<boolean> \{\
    const result = await this.dataSource.query(\
      `UPDATE outbox_events\
          SET status = 'PENDING', retry_count = 0, next_retry_at = now(),\
              last_error = 'requeued_by:' || $2\
        WHERE id = $1 AND status = 'FAILED'\
        RETURNING id`,\
      [eventId, actor],\
    );\
    await this.refreshGauges();\
    return result.length > 0;\
  \}\
\
  async refreshGauges(): Promise<void> \{\
    const [row]: Array<\{ pending: string; dead: string \}> = await this.dataSource.query(\
      `SELECT\
         COUNT(*) FILTER (WHERE status IN ('PENDING','PROCESSING'))::text AS pending,\
         COUNT(*) FILTER (WHERE status = 'FAILED')::text AS dead\
       FROM outbox_events`,\
    );\
    this.metrics.setGauge('outbox_pending_total', Number(row.pending));\
    this.metrics.setGauge('outbox_dead_letter_total', Number(row.dead));\
  \}\
\}\
