# Google Cloud Spanner Global ACID Configuration
CONSISTENCY_LEVEL=STRONG
ISOLATION_LEVEL=SERIALIZABLE
MULTI_REGION_QUORUM=ENABLED
COMMIT_TIMESTAMP_RESOLUTION=MICROSECONDS
STALE_READ_MAX_STALENESS=15s
MAX_RETRIES=5
BACKOFF_MULTIPLIER=1.5
