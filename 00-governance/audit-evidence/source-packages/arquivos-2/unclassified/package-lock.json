}

async function createDeviceSecret(): Promise<string> {
const bytes = await Crypto.getRandomBytesAsync(DEVICE_SECRET_BYTES);

return Array.from(bytes)
.map((byte) => byte.toString(16).padStart(2, '0'))
.join('');
}

