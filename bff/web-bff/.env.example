# Porta do BFF local (padrão 3200)
PORT=3200
WEB_ORIGIN=http://localhost:5176
WEBAUTHN_RP_ID=localhost

# Auth: Firebase | KYC: firebase/homolog (local) ou prometeo (sandbox/prod)
# Homolog (firebase/homolog) é bloqueado com NODE_ENV=production — use prometeo.
# Em dev/test, defina ALLOW_HOMOLOG_KYC=true para confirmar ambiente não-produtivo.
ALLOW_HOMOLOG_KYC=
KYC_PROVIDER=firebase
VISION_USE_ADC=true
GOOGLE_VISION_PROJECT_ID=regenera-bank-501015
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_API_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Segredos de integração — produção: Secret Manager | dev local:
#   cd bff/web-bff && npm run pull-secrets
#   (ou PULL_SECRETS=1 npm run dev:canal-web na raiz)
PROMETEO_API_KEY=
# Identity API (KYC CPF) — sandbox (dados fictícios) vs produção/trial (CPF real)
PROMETEO_IDENTITY_BASE_URL=https://identity.sandbox.prometeoapi.com
# Opcional: URL extra (nunca misture chave sandbox com identity.prometeoapi.net)
PROMETEO_IDENTITY_FALLBACK_URL=
# KYC real — sem fallback simulado (obrigatório para abertura de conta)
# Etapa cadastral: PROMETEO + PEP + DATAVALID
# Etapa documento: GOOGLE_VISION
DATAVALID_API_URL=
DATAVALID_API_KEY=
GOOGLE_VISION_API_KEY=
PEP_API_URL=
PEP_API_KEY=
# Open Banking (contas/login) — separado da Identity API
PROMETEO_BASE_URL=https://banking.sandbox.prometeoapi.com
# Payments API + Widget 2.0 (product_id do painel Prometeo)
PROMETEO_WIDGET_ID=
PROMETEO_PAYMENTS_BASE_URL=https://payment.prometeoapi.net
# Payment Monitoring — token que Prometeo envia em verify_token
PROMETEO_WEBHOOK_VERIFY_TOKEN=
JWT_SESSION_SECRET=
# Raphaela — regenera-bank-501015 | billing pós-pago via Vertex (recomendado)
GEMINI_USE_VERTEX=true
GEMINI_GCP_PROJECT_ID=regenera-bank-501015
GEMINI_VERTEX_LOCATION=us-central1
# Fallback AI Studio (Prepay): GEMINI_API_KEY=AIza…
GEMINI_API_KEY=
GEMINI_API_KEY_FALLBACK=
# GEMINI_ENABLE_PREVIEW=true  # maps/search/thinking (gasta mais quota)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DATABASE_URL=