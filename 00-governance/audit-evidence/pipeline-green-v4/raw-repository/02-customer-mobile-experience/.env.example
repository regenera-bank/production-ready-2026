# .env.example
# segredo real não mora aqui.
# este arquivo é contrato, não cofre.

NODE_ENV=development

# backend only
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
JWT_NEURAL_SECRET=replace-with-secret-manager-value
PROMETEO_API_KEY=replace-with-secret-manager-value
GEMINI_API_KEY=replace-with-secret-manager-value

# frontend/mobile public when needed
VITE_API_URL=https://example.run.app/v1
VITE_FIREBASE_API_KEY=public-key-restricted-by-domain-and-app-check
