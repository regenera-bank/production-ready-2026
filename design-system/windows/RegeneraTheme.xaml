<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="RegeneraTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <LinearGradientBrush x:Key="Regenera.Background.Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Regenera.BackgroundDeep.Color}" Offset="0" />
        <GradientStop Color="{StaticResource Regenera.GradientStart.Color}" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="Regenera.Window" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Regenera.BackgroundDeep.Brush}" />
        <Setter Property="Foreground" Value="{StaticResource Regenera.TextPrimary.Brush}" />
        <Setter Property="FontFamily" Value="{StaticResource Regenera.FontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource Regenera.FontSize.Body}" />
    </Style>

    <Style x:Key="Regenera.Text.Headline" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Regenera.TextPrimary.Brush}" />
        <Setter Property="FontSize" Value="{StaticResource Regenera.FontSize.Headline}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Regenera.Text.Title" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Regenera.TextPrimary.Brush}" />
        <Setter Property="FontSize" Value="{StaticResource Regenera.FontSize.Title}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Regenera.Text.Caption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Regenera.TextSecondary.Brush}" />
        <Setter Property="FontSize" Value="{StaticResource Regenera.FontSize.Caption}" />
    </Style>

    <Style x:Key="Regenera.Panel.Surface" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Regenera.BackgroundSurface.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Regenera.Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Regenera.Radius.Md}" />
        <Setter Property="Padding" Value="{StaticResource Regenera.Spacing.Md}" />
    </Style>

    <Style x:Key="Regenera.Button.Primary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Regenera.Primary.Brush}" />
        <Setter Property="Foreground" Value="{StaticResource Regenera.BackgroundDeep.Brush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Regenera.Radius.Sm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Regenera.Button.Ghost" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Regenera.TextPrimary.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Regenera.Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Regenera.Radius.Sm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Regenera.Nav.Item" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Regenera.TextSecondary.Brush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="{StaticResource Regenera.Radius.Sm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#3322D3EE" />
                            <Setter Property="Foreground" Value="{StaticResource Regenera.Primary.Brush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A22D3EE" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Regenera.Nav.List" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Regenera.Nav.Item}" />
    </Style>

    <Style x:Key="Regenera.Badge.Success" TargetType="Border">
        <Setter Property="Background" Value="#3322C55E" />
        <Setter Property="BorderBrush" Value="{StaticResource Regenera.Success.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Regenera.Radius.Sm}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="Regenera.Badge.Warning" TargetType="Border">
        <Setter Property="Background" Value="#33F59E0B" />
        <Setter Property="BorderBrush" Value="{StaticResource Regenera.Warning.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Regenera.Radius.Sm}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="Regenera.Badge.Danger" TargetType="Border">
        <Setter Property="Background" Value="#33EF4444" />
        <Setter Property="BorderBrush" Value="{StaticResource Regenera.Danger.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Regenera.Radius.Sm}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

</ResourceDictionary>