NODE_ENV=production
PORT=8443
HOST=0.0.0.0
TLS_CERT_PATH=/run/secrets/tls.crt
TLS_KEY_PATH=/run/secrets/tls.key
TLS_CA_PATH=/run/secrets/client-ca.crt
OIDC_ISSUER=https://identity.example.com
OIDC_AUDIENCE=regenera-partner-api
JWKS_URL=https://identity.example.com/.well-known/jwks.json
CORE_API_BASE_URL=https://core-api.example.internal/v1
CORE_CLIENT_CERT_PATH=/run/secrets/core-client.crt
CORE_CLIENT_KEY_PATH=/run/secrets/core-client.key
CORE_CA_PATH=/run/secrets/core-ca.crt
REDIS_URL=rediss://redis.example.internal:6379
DOCS_ENABLED=false
