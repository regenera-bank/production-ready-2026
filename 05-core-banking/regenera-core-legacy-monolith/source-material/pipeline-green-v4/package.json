{
  "name": "@regenera/bank-core",
  "version": "4.0.0",
  "description": "Core Banking Ledger & Financial Settlement Engine",
  "private": true,
  "license": "UNLICENSED",
  "author": {
    "name": "Paulo Ricardo de Leão",
    "email": "paulo@regenerabank.app",
    "id": "RG-2098233287"
  },
  "maintainers": [
    {
      "name": "Raphaela Cerveski",
      "email": "ceo@regenerabank.app"
    }
  ],
  "homepage": "https://regenerabank.app",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:ci": "jest --ci",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --forceExit",
    "test:watch": "jest --watch",
    "test:ledger:invariants": "jest test/ledger-invariants.spec.ts --forceExit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "migration:generate": "typeorm migration:generate -d src/data-source.ts src/migrations",
    "migration:run": "TYPEORM_RUNTIME=ts typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:revert": "TYPEORM_RUNTIME=ts typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "migration:run:dist": "TYPEORM_RUNTIME=js typeorm migration:run -d dist/data-source.js",
    "migration:revert:dist": "TYPEORM_RUNTIME=js typeorm migration:revert -d dist/data-source.js"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.5.0",
    "@google-cloud/compute": "^6.13.0",
    "@google-cloud/documentai": "^8.1.0",
    "@google-cloud/pubsub": "^4.1.0",
    "@google-cloud/recaptcha-enterprise": "^5.5.0",
    "@google-cloud/run": "^3.2.1",
    "@google-cloud/secret-manager": "^5.0.1",
    "@google-cloud/spanner": "^7.1.0",
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/text-to-speech": "^5.0.0",
    "@google-cloud/vertexai": "^1.0.0",
    "@google-cloud/vision": "^5.3.7",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/websockets": "^10.3.0",
    "argon2": "^0.44.0",
    "axios": "^1.16.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
