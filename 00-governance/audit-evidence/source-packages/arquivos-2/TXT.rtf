import \{ Injectable, Logger \} from '@nestjs/common';\
import \{ DataSource \} from 'typeorm';\
import \{ MetricsService \} from '../metrics/metrics.service';\
\
export type MismatchKind =\
  | 'UNBALANCED_ENTRY'\
  | 'BROKEN_HASH_CHAIN'\
  | 'PIX_STUCK'\
  | 'PIX_STATE_WITHOUT_LEDGER'\
  | 'OUTBOX_STALE';\
\
export interface ReconciliationReport \{\
  ranAt: string;\
  checked: \{ entries: number; accounts: number; payments: number \};\
  mismatches: Array<\{ kind: MismatchKind; id: string; detail: string \}>;\
\}\
\
const STUCK_PIX_MINUTES = 15;\
const STALE_OUTBOX_MINUTES = 10;\
\
@Injectable()\
export class ReconciliationJob \{\
  private readonly logger = new Logger(ReconciliationJob.name);\
\
  constructor(\
    private readonly dataSource: DataSource,\
    private readonly metrics: MetricsService,\
  ) \{\}\
\
  async run(): Promise<ReconciliationReport> \{\
    const mismatches: ReconciliationReport['mismatches'] = [];\
\
    const unbalanced: Array<\{ entry_id: string; imbalance: string \}> = await this.dataSource.query(\
      `SELECT entry_id, SUM(CASE WHEN direction = 'DEBIT' THEN amount_cents\
                                 ELSE -amount_cents END)::text AS imbalance\
         FROM ledger_lines\
        GROUP BY entry_id\
       HAVING SUM(CASE WHEN direction = 'DEBIT' THEN amount_cents ELSE -amount_cents END) <> 0`,\
    );\
    for (const row of unbalanced) \{\
      mismatches.push(\{\
        kind: 'UNBALANCED_ENTRY',\
        id: row.entry_id,\
        detail: `imbalanceCents=$\{row.imbalance\}`,\
      \});\
    \}\
\
    // Recalcula a cadeia inteira de cada conta; qualquer elo previous_hash\
    // que n\'e3o aponte para o hash anterior denuncia adultera\'e7\'e3o ou perda.\
    const broken: Array<\{ ledger_account_id: string; line_id: string \}> = await this.dataSource.query(\
      `SELECT curr.ledger_account_id, curr.id AS line_id\
         FROM ledger_lines curr\
         LEFT JOIN LATERAL (\
           SELECT line_hash FROM ledger_lines prev\
            WHERE prev.ledger_account_id = curr.ledger_account_id\
              AND prev.line_seq < curr.line_seq\
            ORDER BY prev.line_seq DESC LIMIT 1) prev ON true\
        WHERE curr.previous_hash <> COALESCE(prev.line_hash, repeat('0', 64))`,\
    );\
    for (const row of broken) \{\
      mismatches.push(\{\
        kind: 'BROKEN_HASH_CHAIN',\
        id: row.line_id,\
        detail: `account=$\{row.ledger_account_id\}`,\
      \});\
    \}\
\
    const stuck: Array<\{ id: string; status: string; updated_at: string \}> = await this.dataSource.query(\
      `SELECT id, status, updated_at::text\
         FROM pix_payments\
        WHERE status IN ('AUTHORIZED','DEBITED','SENT')\
          AND updated_at < now() - ($1 || ' minutes')::interval`,\
      [String(STUCK_PIX_MINUTES)],\
    );\
    for (const row of stuck) \{\
      mismatches.push(\{\
        kind: 'PIX_STUCK',\
        id: row.id,\
        detail: `status=$\{row.status\} desde $\{row.updated_at\}`,\
      \});\
    \}\
\
    const orphan: Array<\{ id: string; status: string \}> = await this.dataSource.query(\
      `SELECT p.id, p.status\
         FROM pix_payments p\
         LEFT JOIN ledger_entries e ON e.id = p.ledger_entry_id\
        WHERE p.status IN ('DEBITED','SENT','SETTLED') AND e.id IS NULL`,\
    );\
    for (const row of orphan) \{\
      mismatches.push(\{\
        kind: 'PIX_STATE_WITHOUT_LEDGER',\
        id: row.id,\
        detail: `status=$\{row.status\} sem lan\'e7amento cont\'e1bil`,\
      \});\
    \}\
\
    const stale: Array<\{ id: string; event_type: string; created_at: string \}> = await this.dataSource.query(\
      `SELECT id, event_type, created_at::text\
         FROM outbox_events\
        WHERE status IN ('PENDING','PROCESSING')\
          AND created_at < now() - ($1 || ' minutes')::interval`,\
      [String(STALE_OUTBOX_MINUTES)],\
    );\
    for (const row of stale) \{\
      mismatches.push(\{\
        kind: 'OUTBOX_STALE',\
        id: row.id,\
        detail: `$\{row.event_type\} criado em $\{row.created_at\}`,\
      \});\
    \}\
\
    const [counts]: Array<\{ entries: string; accounts: string; payments: string \}> =\
      await this.dataSource.query(\
        `SELECT (SELECT COUNT(*) FROM ledger_entries)::text AS entries,\
                (SELECT COUNT(*) FROM ledger_accounts)::text AS accounts,\
                (SELECT COUNT(*) FROM pix_payments)::text AS payments`,\
      );\
\
    for (const mismatch of mismatches) \{\
      this.metrics.increment('reconciliation_mismatch_total', \{ kind: mismatch.kind \});\
      this.logger.warn(`Diverg\'eancia $\{mismatch.kind\} em $\{mismatch.id\}: $\{mismatch.detail\}`);\
    \}\
\
    const report: ReconciliationReport = \{\
      ranAt: new Date().toISOString(),\
      checked: \{\
        entries: Number(counts.entries),\
        accounts: Number(counts.accounts),\
        payments: Number(counts.payments),\
      \},\
      mismatches,\
    \};\
\
    await this.dataSource.query(\
      `INSERT INTO outbox_events\
         (aggregate_type, aggregate_id, event_type, payload, correlation_id)\
       VALUES ('RECONCILIATION', gen_random_uuid(), 'RECONCILIATION_COMPLETED',\
               $1::jsonb, gen_random_uuid())`,\
      [JSON.stringify(\{ mismatchCount: mismatches.length, checked: report.checked \})],\
    );\
    return report;\
  \}\
\}\
