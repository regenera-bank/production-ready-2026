<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Regenera design tokens — aligned with design-system/tokens/color.json and AGENTS.md -->
    <!-- primary: #22d3ee, bg-deep: #020617, navy: #1e3a8a -->

    <Color x:Key="Regenera.Primary.Color">#FF22D3EE</Color>
    <Color x:Key="Regenera.PrimaryStrong.Color">#FF0891B2</Color>
    <Color x:Key="Regenera.BackgroundDeep.Color">#FF020617</Color>
    <Color x:Key="Regenera.BackgroundSurface.Color">#FF0F172A</Color>
    <Color x:Key="Regenera.GradientStart.Color">#FF1E3A8A</Color>
    <Color x:Key="Regenera.TextPrimary.Color">#FFF8FAFC</Color>
    <Color x:Key="Regenera.TextSecondary.Color">#FF94A3B8</Color>
    <Color x:Key="Regenera.Success.Color">#FF22C55E</Color>
    <Color x:Key="Regenera.Warning.Color">#FFF59E0B</Color>
    <Color x:Key="Regenera.Danger.Color">#FFEF4444</Color>
    <Color x:Key="Regenera.Unknown.Color">#FFD946EF</Color>
    <Color x:Key="Regenera.Border.Color">#FF1E293B</Color>

    <SolidColorBrush x:Key="Regenera.Primary.Brush" Color="{StaticResource Regenera.Primary.Color}" />
    <SolidColorBrush x:Key="Regenera.PrimaryStrong.Brush" Color="{StaticResource Regenera.PrimaryStrong.Color}" />
    <SolidColorBrush x:Key="Regenera.BackgroundDeep.Brush" Color="{StaticResource Regenera.BackgroundDeep.Color}" />
    <SolidColorBrush x:Key="Regenera.BackgroundSurface.Brush" Color="{StaticResource Regenera.BackgroundSurface.Color}" />
    <SolidColorBrush x:Key="Regenera.GradientStart.Brush" Color="{StaticResource Regenera.GradientStart.Color}" />
    <SolidColorBrush x:Key="Regenera.TextPrimary.Brush" Color="{StaticResource Regenera.TextPrimary.Color}" />
    <SolidColorBrush x:Key="Regenera.TextSecondary.Brush" Color="{StaticResource Regenera.TextSecondary.Color}" />
    <SolidColorBrush x:Key="Regenera.Success.Brush" Color="{StaticResource Regenera.Success.Color}" />
    <SolidColorBrush x:Key="Regenera.Warning.Brush" Color="{StaticResource Regenera.Warning.Color}" />
    <SolidColorBrush x:Key="Regenera.Danger.Brush" Color="{StaticResource Regenera.Danger.Color}" />
    <SolidColorBrush x:Key="Regenera.Unknown.Brush" Color="{StaticResource Regenera.Unknown.Color}" />
    <SolidColorBrush x:Key="Regenera.Border.Brush" Color="{StaticResource Regenera.Border.Color}" />

    <sys:Double x:Key="Regenera.Spacing.Xs">4</sys:Double>
    <sys:Double x:Key="Regenera.Spacing.Sm">8</sys:Double>
    <sys:Double x:Key="Regenera.Spacing.Md">16</sys:Double>
    <sys:Double x:Key="Regenera.Spacing.Lg">24</sys:Double>
    <sys:Double x:Key="Regenera.Spacing.Xl">32</sys:Double>

    <CornerRadius x:Key="Regenera.Radius.Sm">6</CornerRadius>
    <CornerRadius x:Key="Regenera.Radius.Md">10</CornerRadius>
    <CornerRadius x:Key="Regenera.Radius.Lg">16</CornerRadius>

    <FontFamily x:Key="Regenera.FontFamily">Segoe UI, Manrope, Arial</FontFamily>
    <sys:Double x:Key="Regenera.FontSize.Body">14</sys:Double>
    <sys:Double x:Key="Regenera.FontSize.Caption">12</sys:Double>
    <sys:Double x:Key="Regenera.FontSize.Title">20</sys:Double>
    <sys:Double x:Key="Regenera.FontSize.Headline">28</sys:Double>

</ResourceDictionary>