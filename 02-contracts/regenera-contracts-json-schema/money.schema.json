{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "currency",
    "minorUnits"
  ],
  "properties": {
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "minorUnits": {
      "type": "string",
      "pattern": "^-?[0-9]+$"
    }
  },
  "additionalProperties": false
}
