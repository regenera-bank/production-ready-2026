      if (env[flag] === 'true' || env[flag] === '1') \{\
        violations.push(`Flag proibida em $\{mode\}: $\{flag\}`);\
      \}\
    \}\
    if (env.NODE_ENV !== 'production') \{\
      violations.push(\
        `Incoer\'eancia: RUNTIME_MODE=$\{mode\} exige NODE_ENV=production (atual: $\{env.NODE_ENV ?? 'indefinido'\})`,\
      );\
    \}\
