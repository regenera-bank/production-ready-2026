import \{ Body, Controller, Headers, HttpCode, Post, Res, UnauthorizedException \} from '@nestjs/common';\
import type \{ Response \} from 'express';\
import \{ RateLimit, RATE_LIMIT_POLICIES \} from '../common/rate-limit.guard';\
import \{ SessionService \} from './session.service';\
\
interface LoginBody \{\
  userId?: string;\
  deviceFingerprint?: string;\
  platform?: 'WEB' | 'IOS' | 'ANDROID';\
  deviceName?: string;\
  sandboxCredential?: string;\
\}\
\
@Controller('auth')\
export class AuthController \{\
  constructor(private readonly sessions: SessionService) \{\}\
\
  // Este endpoint \'e9 sandbox por desenho. Produ\'e7\'e3o deve trocar por Firebase/OIDC/MFA\
  // antes de abrir sess\'e3o. Aqui n\'e3o h\'e1 senha falsa, nem token artificial.\
  @Post('login')\
  @HttpCode(201)\
  @RateLimit(RATE_LIMIT_POLICIES.authLogin)\
  async login(\
    @Body() body: LoginBody,\
    @Headers('x-forwarded-for') forwardedFor: string | undefined,\
    @Headers('user-agent') userAgent: string | undefined,\
    @Res(\{ passthrough: true \}) response: Response,\
  ): Promise<\{ sessionId: string; familyId: string; refreshTokenTransport: 'HTTP_ONLY_COOKIE' \}> \{\
    if (process.env.RUNTIME_MODE === 'PRODUCTION') \{\
      throw new UnauthorizedException(\{ code: 'AUTH_PROVIDER_REQUIRED' \});\
    \}\
    if (!body.userId || !body.deviceFingerprint || body.sandboxCredential !== 'SANDBOX_ONLY') \{\
      throw new UnauthorizedException(\{ code: 'SANDBOX_CREDENTIAL_REQUIRED' \});\
    \}\
    const issued = await this.sessions.open(\{\
      userId: body.userId,\
      fingerprint: body.deviceFingerprint,\
      platform: body.platform ?? 'WEB',\
      deviceName: body.deviceName ?? 'sandbox-device',\
      ip: forwardedFor?.split(',')[0]?.trim() || '127.0.0.1',\
      userAgent: userAgent ?? 'unknown',\
    \});\
    response.cookie(issued.cookie.name, issued.cookie.value, issued.cookie);\
    return \{\
      sessionId: issued.sessionId,\
      familyId: issued.familyId,\
      refreshTokenTransport: 'HTTP_ONLY_COOKIE',\
    \};\
  \}\
\}\
