export type ProviderDomain = 'PIX' | 'PIX_KEY' | 'KYC' | 'AML' | 'OPEN_FINANCE' | 'NOTIFICATION' | 'FRAUD';\
\
export interface AdapterRegistration<T> \{\
  domain: ProviderDomain;\
  implementation: string;\
  isMock: boolean;\
  factory: () => T;\
\}\
\
export class AdapterResolver \{\
  private readonly registry = new Map<ProviderDomain, AdapterRegistration<unknown>>();\
\
  constructor(private readonly mode: RuntimeMode) \{\}\
\
  register<T>(registration: AdapterRegistration<T>): void \{\
    const strict = this.mode === RuntimeMode.PRODUCTION || this.mode === RuntimeMode.SANDBOX;\
    if (strict && registration.isMock) \{\
      throw new ProviderIntegrationError(\
        registration.domain,\
        'register',\
        false,\
        undefined,\
        `Adapter mock recusado em $\{this.mode\}: $\{registration.implementation\}`,\
      );\
    \}\
    if (this.registry.has(registration.domain)) \{\
      throw new ProviderIntegrationError(registration.domain, 'register', false, undefined,\
        `Dom\'ednio $\{registration.domain\} j\'e1 possui adapter registrado`);\
    \}\
    this.registry.set(registration.domain, registration);\
  \}\
\
  resolve<T>(domain: ProviderDomain): T \{\
    const registration = this.registry.get(domain);\
    if (!registration) \{\
      throw new ProviderIntegrationError(domain, 'resolve', false, undefined,\
        `Nenhum adapter registrado para $\{domain\}`);\
    \}\
    return registration.factory() as T;\
  \}\
\
  bindings(): Array<\{ domain: ProviderDomain; implementation: string; isMock: boolean \}> \{\
    return [...this.registry.values()].map((\{ domain, implementation, isMock \}) => (\{\
      domain,\
      implementation,\
      isMock,\
    \}));\
  \}\
\}\
