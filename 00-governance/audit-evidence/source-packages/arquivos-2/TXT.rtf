\
// gerador gen\'e9rico. tr\'eas m\'e1quinas hoje, a quarta usa a mesma f\'e1brica\
// em vez de copiar e colar if encadeado \'97 j\'e1 vi esse filme, termina mal.\
function buildAssert<S extends string>(\
  machine: string,\
  table: Readonly<Record<S, readonly S[]>>,\
) \{\
  return \{\
    canTransition(from: S, to: S): boolean \{\
      return table[from]?.includes(to) ?? false;\
    \},\
    assertTransition(from: S, to: S): void \{\
      if (!(table[from]?.includes(to) ?? false)) \{\
        throw new IllegalStateTransitionError(machine, from, to);\
      \}\
    \},\
    nextStates(from: S): readonly S[] \{\
      return table[from] ?? [];\
    \},\
    isTerminal(state: S): boolean \{\
      return (table[state] ?? []).length === 0;\
    \},\
  \};\
\}\
\
