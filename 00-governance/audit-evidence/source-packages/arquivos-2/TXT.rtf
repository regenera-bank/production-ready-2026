@Injectable()\
export class MetricsService \{\
  private readonly counters = new Map<string, number>();\
  private readonly gauges = new Map<string, number>();\
\
  increment(name: CounterName, labels: LabelSet = \{\}, value = 1): void \{\
    if (value <= 0 || !Number.isFinite(value)) return;\
    const key = `$\{name\}$\{serializeLabels(labels)\}`;\
    this.counters.set(key, (this.counters.get(key) ?? 0) + value);\
  \}\
\
  setGauge(name: GaugeName, value: number, labels: LabelSet = \{\}): void \{\
    if (!Number.isFinite(value)) return;\
    this.gauges.set(`$\{name\}$\{serializeLabels(labels)\}`, value);\
  \}\
\
  render(): string \{\
    const lines: string[] = [];\
    for (const [name, help] of Object.entries(COUNTER_HELP)) \{\
      lines.push(`# HELP $\{name\} $\{help\}`, `# TYPE $\{name\} counter`);\
      let emitted = false;\
      for (const [key, value] of this.counters) \{\
        if (key === name || key.startsWith(`$\{name\}\{`)) \{\
          lines.push(`$\{key\} $\{value\}`);\
          emitted = true;\
        \}\
      \}\
      if (!emitted) lines.push(`$\{name\} 0`);\
    \}\
    for (const [name, help] of Object.entries(GAUGE_HELP)) \{\
      lines.push(`# HELP $\{name\} $\{help\}`, `# TYPE $\{name\} gauge`);\
      let emitted = false;\
      for (const [key, value] of this.gauges) \{\
        if (key === name || key.startsWith(`$\{name\}\{`)) \{\
          lines.push(`$\{key\} $\{value\}`);\
          emitted = true;\
        \}\
      \}\
      if (!emitted) lines.push(`$\{name\} 0`);\
    \}\
    return `$\{lines.join('\\n')\}\\n`;\
  \}\
\
  snapshot(): \{ counters: ReadonlyMap<string, number>; gauges: ReadonlyMap<string, number> \} \{\
    return \{ counters: this.counters, gauges: this.gauges \};\
  \}\
\}\
