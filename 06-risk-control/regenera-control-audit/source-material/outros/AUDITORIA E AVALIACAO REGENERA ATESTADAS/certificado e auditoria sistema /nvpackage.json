{
  "name": "regenera-bank-blockchain-certificate",
  "version": "1.0.0",
  "description": "Sistema de Certificação Blockchain Enterprise-Grade para Regenera Bank",
  "author": "Don Paulo Ricardo, PhD (ORCID: 0000-0003-3719-717X)",
  "license": "UNLICENSED",
  "private": true,
  "keywords": [
    "blockchain",
    "certificate",
    "nft",
    "polygon",
    "ethereum",
    "ipfs",
    "smart-contract",
    "regenera-bank"
  ],
  "scripts": {
    "========== DEVELOPMENT ==========": "",
    "dev": "hardhat node",
    "console": "hardhat console",
    "accounts": "hardhat accounts",
    "clean": "hardhat clean && rm -rf cache artifacts output",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "test:gas": "REPORT_GAS=true hardhat test",
    "========== BLOCKCHAIN DEPLOYMENT ==========": "",
    "blockchain:deploy:local": "hardhat run scripts/deploy-certificate.js --network localhost",
    "blockchain:deploy:testnet": "hardhat run scripts/deploy-certificate.js --network mumbai",
    "blockchain:deploy:mainnet": "hardhat run scripts/deploy-certificate.js --network polygon",
    "blockchain:verify": "hardhat run scripts/verify-blockchain.js --network polygon",
    "========== IPFS ==========": "",
    "ipfs:upload": "node scripts/upload-to-ipfs.js",
    "ipfs:pin": "node scripts/pin-to-ipfs.js",
    "ipfs:verify": "node scripts/verify-ipfs.js",
    "========== CERTIFICATES & BADGES ==========": "",
    "badge:generate": "node scripts/generate-badge.js",
    "badge:deploy": "node scripts/deploy-badge.js",
    "badge:test": "open blockchain-certificate-badge.html",
    "certificate:generate": "node scripts/generate-certificate.js",
    "========== VERIFICATION ==========": "",
    "verify:all": "npm run verify:hashes && npm run verify:blockchain && npm run verify:ipfs",
    "verify:hashes": "node scripts/verify-hashes.js",
    "verify:blockchain": "hardhat run scripts/verify-blockchain.js --network polygon",
    "verify:ipfs": "node scripts/verify-ipfs.js",
    "verify:contract": "hardhat verify --network polygon",
    "========== REPORTING ==========": "",
    "report:verification": "node scripts/generate-verification-report.js",
    "report:gas": "REPORT_GAS=true hardhat test",
    "report:coverage": "hardhat coverage && open coverage/index.html",
    "========== ONE-CLICK DEPLOYMENT ==========": "",
    "deploy:immortality": "npm run blockchain:deploy:mainnet && npm run ipfs:upload && npm run badge:generate && npm run verify:all && npm run report:verification",
    "deploy:testnet": "npm run blockchain:deploy:testnet && npm run ipfs:upload && npm run badge:generate && npm run verify:all",
    "========== MAINTENANCE ==========": "",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write 'scripts/**/*.js' 'test/**/*.js'",
    "size-limit": "npx size-limit",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "========== INFO ==========": "",
    "info": "node -e \"console.log(require('./package.json'))\"",
    "help": "echo '\n📖 REGENERA BANK - BLOCKCHAIN CERTIFICATE\n\nMain Commands:\n  npm run deploy:immortality - Deploy tudo (mainnet)\n  npm run deploy:testnet - Deploy tudo (testnet)\n  npm run verify:all - Verificar tudo\n  npm run badge:generate - Gerar badge HTML\n\nDevelopment:\n  npm run dev - Hardhat local node\n  npm run test - Run tests\n  npm run compile - Compile contracts\n\nDocumentation:\n  See README_BLOCKCHAIN_CERTIFICATE.md\n'"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "chai": "^4.3.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "ipfs-http-client": "^60.0.0",
    "pinata-sdk": "^2.1.0",
    "prettier": "^3.1.0",
    "prettier-plugin-solidity": "^1.2.0",
    "solidity-coverage": "^0.8.5",
    "typechain": "^8.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/regenera-bank/blockchain-certificate"
  },
  "bugs": {
    "url": "https://github.com/regenera-bank/blockchain-certificate/issues"
  },
  "homepage": "https://regenerabank.com/certificate"
}
