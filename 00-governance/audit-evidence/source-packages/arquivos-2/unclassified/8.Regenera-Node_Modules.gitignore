# .gitignore

#

# arquivo ignorado também é controle de segurança.

#

# segredo não vai pro git.

# build não vai pro git.

# lixo de máquina não vai pro git.

#

# se isso aqui falhar,

# o vazamento já começa no commit.

# ---------------------------------------------------------------------------

# dependências

# ---------------------------------------------------------------------------

node_modules/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# ---------------------------------------------------------------------------

# Expo

# ---------------------------------------------------------------------------

.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# ---------------------------------------------------------------------------

# React Native / Metro

# ---------------------------------------------------------------------------

.metro-health-check*
*.packager.env

# ---------------------------------------------------------------------------

# builds nativos gerados

# ---------------------------------------------------------------------------

/ios/
/android/

# ---------------------------------------------------------------------------

# Android

# ---------------------------------------------------------------------------

.gradle/
.kotlin/
local.properties
*.apk
*.aab

# ---------------------------------------------------------------------------

# iOS / Xcode

# ---------------------------------------------------------------------------

build/
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcuserstate

# ---------------------------------------------------------------------------

# chaves, certificados e perfis

# ---------------------------------------------------------------------------

*.jks
*.keystore
*.p8
*.p12
*.key
*.pem
*.cer
*.csr
*.mobileprovision
*.provisionprofile

# ---------------------------------------------------------------------------

# ambiente local

# ---------------------------------------------------------------------------

.env
.env.*
!.env.example
!.env.test.example

# ---------------------------------------------------------------------------

# TypeScript

# ---------------------------------------------------------------------------

*.tsbuildinfo

# ---------------------------------------------------------------------------

# logs e debug

# ---------------------------------------------------------------------------

npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.log*
*.log

# ---------------------------------------------------------------------------

# cobertura e testes

# ---------------------------------------------------------------------------

coverage/
.nyc_output/
junit.xml
test-results/

# ---------------------------------------------------------------------------

# cache de ferramentas

# ---------------------------------------------------------------------------

.eslintcache
.prettier-cache
.turbo/
.cache/

# ---------------------------------------------------------------------------

# sistema operacional e editor

# ---------------------------------------------------------------------------

.DS_Store
Thumbs.db

.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------

# arquivos de conflito

# ---------------------------------------------------------------------------

*.orig
*.orig.*
*.rej

# ---------------------------------------------------------------------------

# banco local

# ---------------------------------------------------------------------------

*.sqlite
*.sqlite3
*.db
*.db-journal

# ---------------------------------------------------------------------------

# artefatos temporários

# ---------------------------------------------------------------------------

tmp/
temp/
.tmp/
