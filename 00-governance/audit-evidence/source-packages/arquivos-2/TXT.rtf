  async evaluate(\
    senderAccountId: string,\
    asOf: Date,\
    params: StructuringRuleParams = AML_PIX_STRUCTURING_001_DEFAULTS,\
  ): Promise<StructuringEvaluation> \{\
    const windowStart = new Date(asOf.getTime() - params.windowHours * 3_600_000);\
\
    const rows: Array<\{\
      amount_cents: string;\
      receiver_key_hash: string;\
    \}> = await this.dataSource.query(\
      `SELECT amount_cents::text, receiver_key_hash\
         FROM pix_payments\
        WHERE sender_account_id = $1\
          AND status = 'SETTLED'\
          AND settled_at >= $2 AND settled_at <= $3\
          AND amount_cents < $4::bigint`,\
      [senderAccountId, windowStart, asOf, params.singleTxCeilingCents],\
    );\
\
    const ceiling = Money.fromCents(params.singleTxCeilingCents);\
    const nearLimitFloor = ceiling.percentageBps(9000n);\
    let aggregate = Money.zero();\
    let nearLimitHits = 0;\
    const receiverKeys = new Set<string>();\
\
    for (const row of rows) \{\
      const amount = Money.fromCents(row.amount_cents);\
      aggregate = aggregate.add(amount);\
      receiverKeys.add(row.receiver_key_hash);\
      if (amount.compare(nearLimitFloor) >= 0) nearLimitHits += 1;\
    \}\
\
    const c1 =\
      rows.length >= params.minTxCount &&\
      aggregate.compare(Money.fromCents(params.aggregateFloorCents)) >= 0;\
    const c2 = nearLimitHits >= params.nearLimitCount;\
    const c3 = c1 && receiverKeys.size >= params.minDistinctKeys;\
\
    const triggered = c1 || c2;\
    const severity: StructuringEvaluation['severity'] =\
      c1 && c2 && c3 ? 'CRITICAL' : c1 && (c2 || c3) ? 'HIGH' : 'MEDIUM';\
\
    return \{\
      triggered,\
      severity,\
      criteria: \{ c1, c2, c3 \},\
      txCount: rows.length,\
      aggregate,\
      distinctReceiverKeys: receiverKeys.size,\
      windowStart,\
      windowEnd: asOf,\
    \};\
  \}\
